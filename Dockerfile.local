# This dockerfile will build a container using local files and installing the dependencies.
# We will use python 3.12 image.
FROM python:3.12-slim

# Install python and pip
RUN apt-get update && apt-get install -y git python3 python3-pip curl procps && \
    rm -rf /var/lib/apt/lists/*

# Set the working directory
WORKDIR /app

# Copy the application files
COPY requirements.txt .
COPY client_query.py .
COPY gradio_interface.py .
COPY start.sh .
COPY server.json .

# Install Python dependencies
RUN pip3 install --break-system-packages -r requirements.txt

# Make start.sh executable
RUN chmod +x start.sh

# Expose ports (7860 for Gradio, 8000 for API)
EXPOSE 7860 8000

# Create an entrypoint script that starts ollama and pulls the model
RUN echo '#!/bin/bash\n\
bash ./start.sh\n\' > /entrypoint.sh && chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]

